import 'dart:convert';
import 'package:flutter/material.dart';
import 'package:go_router/go_router.dart';
import 'package:image_picker/image_picker.dart';
import 'package:provider/provider.dart';
import '../theme/app_theme.dart';
import '../providers/settings_provider.dart';
import '../providers/favorites_provider.dart';
import 'api_key_screen.dart';

class SettingsScreen extends StatelessWidget {
  const SettingsScreen({super.key});

  @override
  Widget build(BuildContext context) {
    final colorScheme = Theme.of(context).colorScheme;
    final isDark = colorScheme.brightness == Brightness.dark;

    return Scaffold(
      backgroundColor: colorScheme.surface,
      body: Consumer<SettingsProvider>(
        builder: (context, settings, _) {
          return SafeArea(
            child: Column(
              children: [
                // Header
                Padding(
                  padding: const EdgeInsets.fromLTRB(24, 24, 24, 8),
                  child: Column(
                    children: [
                      Text(
                        '設定',
                        style: AppTextStyles.headingMedium.copyWith(
                          color: colorScheme.onSurface,
                          fontSize: 28,
                        ),
                      ),
                      const SizedBox(height: 4),
                      Text(
                        '個人化您的學習體驗',
                        style: AppTextStyles.bodyMedium.copyWith(
                          color: colorScheme.onSurface.withOpacity(0.6),
                        ),
                      ),
                    ],
                  ),
                ),
                Expanded(
                  child: SingleChildScrollView(
                    padding: const EdgeInsets.symmetric(
                        horizontal: 20, vertical: 16),
                    child: Center(
                      child: ConstrainedBox(
                        constraints: const BoxConstraints(maxWidth: 480),
                        child: Column(
                          children: [
                          GestureDetector(
                            onTap: () => _editProfile(context, settings),
                            child: Column(
                              children: [
                                // Avatar
                                Container(
                                  width: 88,
                                  height: 88,
                                  decoration: BoxDecoration(
                                    shape: BoxShape.circle,
                                    color: kPrimary.withOpacity(0.15),
                                    border: Border.all(
                                        color: kPrimary.withOpacity(0.3),
                                        width: 2),
                                    image: settings.userAvatar.startsWith('data:image')
                                        ? DecorationImage(
                                            image: MemoryImage(base64Decode(settings.userAvatar.split(',').last)),
                                            fit: BoxFit.cover,
                                          )
                                        : null,
                                  ),
                                  child: settings.userAvatar.startsWith('data:image')
                                      ? null
                                      : Center(
                                          child: Text(
                                            settings.userAvatar,
                                            style: const TextStyle(fontSize: 44),
                                          ),
                                        ),
                                ),
                                const SizedBox(height: 12),
                                Row(
                                  mainAxisAlignment: MainAxisAlignment.center,
                                  children: [
                                    Text(
                                      settings.userName,
                                      style: AppTextStyles.headingMedium.copyWith(
                                          fontSize: 20),
                                    ),
                                    const SizedBox(width: 4),
                                    const Icon(Icons.edit, size: 16, color: kPrimary),
                                  ],
                                ),
                              ],
                            ),
                          ),
                            Text(
                              supabase_flutter.Supabase.instance.client.auth.currentUser?.email ?? 'devocab-user@example.com',
                              style: AppTextStyles.bodyMedium.copyWith(
                                color: colorScheme.onSurface.withOpacity(0.6),
                              ),
                            ),
                            const SizedBox(height: 32),
                            // Settings items
                            _SettingItem(
                              icon: Icons.vpn_key_outlined,
                              label: 'API 金鑰設置',
                              onTap: () => Navigator.of(context).push(
                                MaterialPageRoute(
                                    builder: (_) => const ApiKeyScreen()),
                              ),
                            ),
                            const SizedBox(height: 12),
                            const SizedBox(height: 12),
                            _SettingItem(
                              icon: Icons.restart_alt_outlined,
                              label: '學習進度重置',
                              onTap: () => _confirmReset(context),
                            ),
                            const SizedBox(height: 12),
                            _SettingItem(
                              icon: Icons.logout,
                              label: '登出帳號',
                              isDestructive: true,
                              onTap: () => _logout(context),
                            ),
                            const SizedBox(height: 32),
                            Text(
                              'DEVOCAB VERSION 2.0.4',
                              style: AppTextStyles.label.copyWith(
                                color: const Color(0xFFA0A4A0),
                                fontSize: 10,
                              ),
                            ),
                            const SizedBox(height: 80),
                          ],
                        ),
                      ),
                    ),
                  ),
                ),
              ],
            ),
          );
        },
      ),
    );
  }

  void _editProfile(BuildContext context, SettingsProvider settings) {
    final nameCtrl = TextEditingController(text: settings.userName);
    String currentAvatar = settings.userAvatar;

    showDialog(
      context: context,
      builder: (ctx) => StatefulBuilder(
        builder: (context, setState) {
          return AlertDialog(
            title: const Text('編輯個人資料'),
            content: Column(
              mainAxisSize: MainAxisSize.min,
              children: [
                GestureDetector(
                  onTap: () async {
                    final picker = ImagePicker();
                    final pickedFile = await picker.pickImage(source: ImageSource.gallery, maxWidth: 300, maxHeight: 300);
                    if (pickedFile != null) {
                      final bytes = await pickedFile.readAsBytes();
                      final base64String = base64Encode(bytes);
                      setState(() {
                        // Use basic mime type for displaying, since Image.memory just needs the base64 part
                        // but we store the prefix to know it's an image.
                        currentAvatar = 'data:image/jpeg;base64,$base64String';
                      });
                    }
                  },
                  child: Container(
                    width: 80,
                    height: 80,
                    decoration: BoxDecoration(
                      shape: BoxShape.circle,
                      color: kPrimary.withOpacity(0.1),
                      border: Border.all(color: kPrimary.withOpacity(0.3)),
                      image: currentAvatar.startsWith('data:image')
                          ? DecorationImage(
                              image: MemoryImage(base64Decode(currentAvatar.split(',').last)),
                              fit: BoxFit.cover,
                            )
                          : null,
                    ),
                    child: currentAvatar.startsWith('data:image')
                        ? null
                        : Center(
                            child: Text(
                              currentAvatar,
                              style: const TextStyle(fontSize: 32),
                            ),
                          ),
                  ),
                ),
                const SizedBox(height: 8),
                TextButton.icon(
                  onPressed: () async {
                     final picker = ImagePicker();
                     final pickedFile = await picker.pickImage(source: ImageSource.gallery, maxWidth: 300, maxHeight: 300);
                     if (pickedFile != null) {
                       final bytes = await pickedFile.readAsBytes();
                       setState(() {
                         currentAvatar = 'data:image/jpeg;base64,${base64Encode(bytes)}';
                       });
                     }
                  },
                  icon: const Icon(Icons.upload_file),
                  label: const Text('上傳圖片'),
                ),
                TextButton(
                  onPressed: () {
                    // Reset to emoji
                    setState(() {
                      currentAvatar = '🍌';
                    });
                  },
                  child: const Text('重置為 Emoji'),
                ),
                const SizedBox(height: 12),
                TextField(
                  controller: nameCtrl,
                  decoration: const InputDecoration(labelText: '名稱'),
                ),
              ],
            ),
            actions: [
              TextButton(
                onPressed: () => Navigator.pop(ctx),
                child: const Text('取消'),
              ),
              TextButton(
                onPressed: () {
                  settings.updateProfile(nameCtrl.text, currentAvatar.isEmpty ? '🍌' : currentAvatar);
                  Navigator.pop(ctx);
                },
                child: const Text('儲存'),
              ),
            ],
          );
        }
      ),
    );
  }

  void _confirmReset(BuildContext context) {
    showDialog(
      context: context,
      builder: (ctx) => AlertDialog(
        title: const Text('重置學習進度'),
        content: const Text('這將會清除所有收藏單字，確定要繼續嗎？'),
        actions: [
          TextButton(
            onPressed: () => Navigator.pop(ctx),
            child: const Text('取消'),
          ),
          TextButton(
            onPressed: () {
              context.read<FavoritesProvider>().clearAll();
              Navigator.pop(ctx);
              ScaffoldMessenger.of(context).showSnackBar(
                const SnackBar(content: Text('學習進度已重置')),
              );
            },
            child:
                const Text('確定', style: TextStyle(color: Colors.red)),
          ),
        ],
      ),
    );
  }

  void _logout(BuildContext context) {
    showDialog(
      context: context,
      builder: (ctx) => AlertDialog(
        title: const Text('登出帳號'),
        content: const Text('確定要登出嗎？'),
        actions: [
          TextButton(
            onPressed: () => Navigator.pop(ctx),
            child: const Text('取消'),
          ),
          TextButton(
            onPressed: () async {
              Navigator.pop(ctx);
              await context.read<SettingsProvider>().clearApiKey();
              if (context.mounted) context.go('/login');
            },
            child: const Text('登出', style: TextStyle(color: Colors.red)),
          ),
        ],
      ),
    );
  }
}

class _SettingItem extends StatelessWidget {
  final IconData icon;
  final String label;
  final VoidCallback? onTap;
  final bool isDestructive;

  const _SettingItem({
    required this.icon,
    required this.label,
    this.onTap,
    this.isDestructive = false,
  });

  Widget build(BuildContext context) {
    final isDark = Theme.of(context).brightness == Brightness.dark;
    final color = isDestructive ? Colors.red.shade400 : Theme.of(context).colorScheme.onSurface;
    final bgColor = isDestructive
        ? Colors.red.withOpacity(0.1)
        : (isDark ? kSurfaceDark : Colors.white);

    return Material(
      color: bgColor,
      borderRadius: BorderRadius.circular(16),
      child: InkWell(
        onTap: onTap,
        borderRadius: BorderRadius.circular(16),
        child: Padding(
          padding: const EdgeInsets.all(16),
          child: Row(
            children: [
              Container(
                width: 44,
                height: 44,
                decoration: BoxDecoration(
                  shape: BoxShape.circle,
                  color: isDestructive
                      ? Colors.red.shade100
                      : kPrimary.withOpacity(0.1),
                ),
                child: Icon(icon,
                    color: isDestructive ? Colors.red.shade400 : kPrimary,
                    size: 22),
              ),
              const SizedBox(width: 16),
              Expanded(
                child: Text(label,
                    style: AppTextStyles.bodyLarge.copyWith(
                      color: color,
                      fontWeight: FontWeight.w500,
                    )),
              ),
              Icon(Icons.chevron_right,
                  color: isDestructive
                      ? Colors.red.shade200
                      : const Color(0xFFCCCCCC)),
            ],
          ),
        ),
      ),
    );
  }
}
